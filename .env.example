# EmbedBench Configuration
# Copy this file to .env and adjust as needed

# Default embedding dimension (for n-gram hasher)
EMBEDBENCH_NGRAM_DIM=5000

# Default n-gram range
EMBEDBENCH_NGRAM_MIN=2
EMBEDBENCH_NGRAM_MAX=4

# Top-K for retrieval evaluation
EMBEDBENCH_TOP_K=5

# Log level
EMBEDBENCH_LOG_LEVEL=INFO
